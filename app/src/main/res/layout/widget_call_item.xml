<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Avatar circle -->
    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/widget_avatar_bg">

        <TextView
            android:id="@+id/tv_initials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- Name + call type + time -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="1dp">

            <ImageView
                android:id="@+id/iv_call_type"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_widget_incoming" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:paddingStart="4dp"
                android:maxLines="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Dial button — the only view with setOnClickFillInIntent -->
    <ImageButton
        android:id="@+id/btn_dial"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_widget_call"
        android:background="@drawable/widget_dial_btn_bg"
        android:contentDescription="Call"
        android:padding="8dp" />

</LinearLayout>
